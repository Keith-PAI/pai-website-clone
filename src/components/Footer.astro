---
import { url } from '../utils/paths';

const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Services',
    links: [
      { label: 'Editing & Production', href: url('/services/editing-production/') },
      { label: 'Meeting Support', href: url('/services/meeting-support/') },
      { label: 'SMS Consulting', href: url('/services/sms-consulting/') },
      { label: 'Pricing', href: url('/services/pricing/') },
      { label: 'Government Services', href: url('/government/') },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About PAI', href: url('/about/') },
      { label: 'Our Team', href: url('/about/team/') },
      { label: 'History', href: url('/about/history/') },
      { label: 'Downloads', href: url('/about/downloads/') },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Blog', href: url('/blog/') },
      { label: 'FRAT Tool', href: 'https://jw2750.github.io/PAI-FRAT/', external: true },
      { label: 'Contact Us', href: url('/contact/') },
    ],
  },
];
---

<footer class="border-t border-navy-100 bg-navy-950 text-navy-300">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2">
          <svg viewBox="0 0 48 48" class="h-9 w-9" aria-hidden="true">
            <rect width="48" height="48" rx="8" fill="#243b53"/>
            <text x="24" y="32" text-anchor="middle" fill="#38b6ff" font-family="Inter, sans-serif" font-weight="800" font-size="24">P</text>
          </svg>
          <div>
            <span class="text-lg font-bold text-white">PAI Consulting</span>
          </div>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-navy-400">
          Expert consulting services in aviation, regulatory affairs, editing, meeting support, and safety management systems since 1978.
        </p>
        <div class="mt-4 flex items-center gap-2">
          <span class="rounded-full bg-navy-800 px-3 py-1 text-xs font-medium text-sky-400">
            Women-Owned Small Business
          </span>
        </div>
        <div class="mt-3 flex items-center gap-2">
          <span class="rounded-full bg-navy-800 px-3 py-1 text-xs font-medium text-navy-300">
            NBAA Member
          </span>
        </div>
      </div>

      <!-- Link Columns -->
      {footerLinks.map((section) => (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
            {section.title}
          </h3>
          <ul class="mt-4 space-y-3">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-navy-400 transition-colors hover:text-sky-400"
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                  {link.external && (
                    <svg class="ml-1 inline h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-navy-800 pt-8 sm:flex-row">
      <div class="text-sm text-navy-500">
        <p>11325 Random Hills Road, Suite 360, Fairfax, VA 22030</p>
        <p class="mt-1">
          <a href="tel:+17039313131" class="hover:text-sky-400">+1 (703) 931-3131</a>
        </p>
      </div>
      <div class="flex items-center gap-4">
        <!-- Social Links -->
        <a href="https://www.facebook.com/paiconsulting" target="_blank" rel="noopener noreferrer" class="text-navy-500 transition-colors hover:text-sky-400" aria-label="Facebook">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/pai-consulting" target="_blank" rel="noopener noreferrer" class="text-navy-500 transition-colors hover:text-sky-400" aria-label="LinkedIn">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://www.instagram.com/paiconsulting" target="_blank" rel="noopener noreferrer" class="text-navy-500 transition-colors hover:text-sky-400" aria-label="Instagram">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/></svg>
        </a>
      </div>
    </div>
    <p class="mt-6 text-center text-xs text-navy-600">
      &copy; {currentYear} PAI Consulting. All rights reserved.
    </p>
  </div>
</footer>
