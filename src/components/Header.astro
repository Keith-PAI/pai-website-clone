---
const currentPath = Astro.url.pathname;

const navItems = [
  {
    label: 'Services',
    href: '/services/editing-production/',
    children: [
      { label: 'Editing & Production', href: '/services/editing-production/' },
      { label: 'Meeting Support', href: '/services/meeting-support/' },
      { label: 'SMS Consulting', href: '/services/sms-consulting/' },
      { label: 'Pricing', href: '/services/pricing/' },
    ],
  },
  { label: 'Government', href: '/government/' },
  { label: 'Blog', href: '/blog/' },
  {
    label: 'About',
    href: '/about/',
    children: [
      { label: 'About PAI', href: '/about/' },
      { label: 'Our Team', href: '/about/team/' },
      { label: 'History', href: '/about/history/' },
      { label: 'Downloads', href: '/about/downloads/' },
    ],
  },
  { label: 'Contact', href: '/contact/' },
];

function isActive(href: string): boolean {
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-navy-100 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <div class="flex items-center">
        <svg viewBox="0 0 48 48" class="h-10 w-10" aria-hidden="true">
          <rect width="48" height="48" rx="8" fill="#102a43"/>
          <text x="24" y="32" text-anchor="middle" fill="#38b6ff" font-family="Inter, sans-serif" font-weight="800" font-size="24">P</text>
        </svg>
        <div class="ml-2">
          <span class="text-lg font-bold leading-none text-navy-900">PAI</span>
          <span class="block text-xs font-medium tracking-wide text-navy-500">CONSULTING</span>
        </div>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex lg:items-center lg:gap-1" aria-label="Main navigation">
      {navItems.map((item) => (
        <div class="group relative">
          <a
            href={item.href}
            class:list={[
              'inline-flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'bg-navy-50 text-sky-600'
                : 'text-navy-700 hover:bg-navy-50 hover:text-navy-900',
            ]}
          >
            {item.label}
            {item.children && (
              <svg class="h-4 w-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
          {item.children && (
            <div class="pointer-events-none absolute left-0 top-full pt-2 opacity-0 transition-all duration-200 group-hover:pointer-events-auto group-hover:opacity-100">
              <div class="w-56 rounded-xl border border-navy-100 bg-white p-2 shadow-lg shadow-navy-900/5">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block rounded-lg px-3 py-2 text-sm transition-colors',
                      isActive(child.href)
                        ? 'bg-navy-50 font-medium text-sky-600'
                        : 'text-navy-700 hover:bg-navy-50 hover:text-navy-900',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
      <a
        href="/contact/"
        class="ml-3 rounded-lg bg-sky-400 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-sky-500"
      >
        Get a Quote
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      type="button"
      id="mobile-menu-btn"
      class="rounded-lg p-2 text-navy-700 hover:bg-navy-50 lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden border-t border-navy-100 bg-white lg:hidden">
    <nav class="mx-auto max-w-7xl space-y-1 px-4 py-4" aria-label="Mobile navigation">
      {navItems.map((item) => (
        <div>
          <a
            href={item.href}
            class:list={[
              'block rounded-lg px-3 py-2 text-base font-medium',
              isActive(item.href)
                ? 'bg-navy-50 text-sky-600'
                : 'text-navy-700 hover:bg-navy-50',
            ]}
          >
            {item.label}
          </a>
          {item.children && (
            <div class="ml-4 space-y-1">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'block rounded-lg px-3 py-2 text-sm',
                    isActive(child.href)
                      ? 'font-medium text-sky-600'
                      : 'text-navy-500 hover:text-navy-700',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="pt-2">
        <a
          href="/contact/"
          class="block rounded-lg bg-sky-400 px-4 py-2.5 text-center text-sm font-semibold text-white"
        >
          Get a Quote
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
