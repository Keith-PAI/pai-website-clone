---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/paths';
---

<BaseLayout title="Downloads & Resources" description="Download PAI Consulting's free Flight Risk Assessment Tool (FRAT), instructions, and printable badge cards.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 flex items-center gap-2 text-sm text-navy-400">
          <a href={url('/')} class="hover:text-sky-400">Home</a>
          <span>/</span>
          <a href={url('/about/')} class="hover:text-sky-400">About</a>
          <span>/</span>
          <span class="text-sky-400">Downloads</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
          Downloads &amp; Resources
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300">
          Free tools and resources to support your aviation safety operations.
        </p>
      </div>
    </div>
  </section>

  <!-- FRAT Tool -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Flight Risk Assessment Tool (FRAT)</h2>
      <p class="mt-3 max-w-2xl text-navy-500">
        A practical tool for evaluating flight risk before every operation. Available as an interactive web tool and printable badge cards.
      </p>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Online Tool -->
        <a
          href="https://jw2750.github.io/PAI-FRAT/"
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-2xl border-2 border-sky-200 bg-sky-50 p-6 transition-all hover:border-sky-400 hover:shadow-md"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/20">
            <svg class="h-6 w-6 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-sky-700 group-hover:text-sky-800">Online FRAT Tool</h3>
          <p class="mt-2 text-sm text-sky-600">Interactive web-based assessment — use it right in your browser.</p>
          <span class="mt-4 inline-flex items-center text-sm font-semibold text-sky-600">
            Open Tool
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
            </svg>
          </span>
        </a>

        <!-- Instructions PDF -->
        <div class="group rounded-2xl border border-navy-100 bg-white p-6 transition-all hover:border-sky-200 hover:shadow-sm">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-navy-100">
            <svg class="h-6 w-6 text-navy-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">FRAT Instructions</h3>
          <p class="mt-2 text-sm text-navy-500">Downloadable PDF with detailed instructions for using the Flight Risk Assessment Tool.</p>
          <span class="mt-4 inline-flex items-center text-sm font-semibold text-sky-500">
            Download PDF
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </span>
        </div>

        <!-- Printable Badge -->
        <div class="group rounded-2xl border border-navy-100 bg-white p-6 transition-all hover:border-sky-200 hover:shadow-sm">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-navy-100">
            <svg class="h-6 w-6 text-navy-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.75 12h.008v.008h-.008V12zm-8.25 0h.008v.008H10.5V12z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">Printable Badge Card</h3>
          <p class="mt-2 text-sm text-navy-500">Print on your home printer, cut along the lines and fold — fits in a standard badge holder.</p>
          <div class="mt-4 space-y-2">
            <span class="inline-flex items-center text-sm font-semibold text-sky-500">
              Front (Home Print)
              <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
            </span>
            <br />
            <span class="inline-flex items-center text-sm font-semibold text-sky-500">
              Back (Home Print)
              <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
            </span>
          </div>
        </div>
      </div>

      <!-- Print Shop Files -->
      <div class="mt-8 rounded-xl border border-navy-200 bg-navy-50 p-6">
        <h3 class="font-bold text-navy-900">Print Shop Versions</h3>
        <p class="mt-2 text-sm text-navy-500">
          Professional card stock versions available for print shop production — front and back files included.
        </p>
      </div>
    </div>
  </section>

  <!-- More Resources Coming -->
  <section class="border-t border-navy-100 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <span class="inline-flex items-center rounded-full bg-sky-400/10 px-3 py-1 text-xs font-semibold text-sky-600">Coming Soon</span>
      <h2 class="mt-4 text-2xl font-bold">More Resources</h2>
      <p class="mt-3 text-navy-500">
        We're building a resource library with definitions of acronyms, links to regulations, and other helpful references. Stay tuned.
      </p>
      <a href={url('/contact/')} class="mt-6 inline-flex items-center text-sm font-semibold text-sky-500 hover:text-sky-600">
        Get notified when new resources are available
        <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
