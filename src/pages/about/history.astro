---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/paths';

const experienceData = [
  { label: 'Aviation Analysis', years: 248, color: 'bg-sky-400' },
  { label: 'Editing & Technical Writing', years: 139, color: 'bg-sky-500' },
  { label: 'Aviation Industry', years: 137, color: 'bg-navy-400' },
  { label: 'Flight Time', years: 91, color: 'bg-navy-500' },
  { label: 'Professional Education', years: 63, color: 'bg-navy-600' },
];

const maxYears = Math.max(...experienceData.map(d => d.years));

const timeline = [
  { year: '1978', title: 'Founded', desc: 'PAI Consulting established, beginning its service to the aerospace industry with paper and typewriters.' },
  { year: '1980s', title: 'Growth & Digitization', desc: 'Transitioned from paper to floppy discs and desktop computers, expanding service capabilities.' },
  { year: '1990s', title: 'Expanded Services', desc: 'Grew the team and broadened service offerings across regulatory affairs, editing, and analysis.' },
  { year: '2000s', title: 'Modern Operations', desc: 'Embraced laptops, virtual meetings, and cloud technology. Expanded government and private sector client base.' },
  { year: '2020', title: 'Virtual Pivot', desc: 'Successfully transitioned to fully virtual operations during COVID-19 without disrupting any client services.' },
  { year: 'Today', title: 'PAI Academy & Beyond', desc: 'Developing PAI Academy, a digital training platform for safety management systems. Continuing to grow and innovate.' },
];
---

<BaseLayout title="History of PAI" description="PAI Consulting has been integral to the aerospace industry since 1978. Learn about our four decades of aviation consulting.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 flex items-center gap-2 text-sm text-navy-400">
          <a href={url('/')} class="hover:text-sky-400">Home</a>
          <span>/</span>
          <a href={url('/about/')} class="hover:text-sky-400">About</a>
          <span>/</span>
          <span class="text-sky-400">History</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
          History of PAI
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300">
          From paper and typewriters to cloud technology — over four decades of adapting, growing, and delivering excellence in aviation consulting.
        </p>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Our Journey</h2>

      <div class="relative mt-12">
        <!-- Timeline line -->
        <div class="absolute left-4 top-0 hidden h-full w-0.5 bg-navy-100 sm:block" aria-hidden="true"></div>

        <div class="space-y-8 sm:space-y-12">
          {timeline.map((item, i) => (
            <div class="relative flex gap-6 sm:gap-8">
              <!-- Dot -->
              <div class="relative z-10 hidden sm:block">
                <div class:list={[
                  'flex h-9 w-9 items-center justify-center rounded-full border-2',
                  i === timeline.length - 1
                    ? 'border-sky-400 bg-sky-400'
                    : 'border-navy-200 bg-white',
                ]}>
                  <div class:list={[
                    'h-2.5 w-2.5 rounded-full',
                    i === timeline.length - 1 ? 'bg-white' : 'bg-navy-300',
                  ]}></div>
                </div>
              </div>

              <div class="flex-1 rounded-xl border border-navy-100 bg-white p-6">
                <span class:list={[
                  'inline-block rounded-full px-3 py-1 text-xs font-bold',
                  i === timeline.length - 1
                    ? 'bg-sky-400/10 text-sky-600'
                    : 'bg-navy-50 text-navy-600',
                ]}>
                  {item.year}
                </span>
                <h3 class="mt-3 text-lg font-bold">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-navy-500">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Combined Experience -->
  <section class="border-t border-navy-100 bg-navy-50/50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Combined Years of Experience</h2>
      <p class="mt-3 max-w-2xl text-navy-500">
        Our team's collective expertise spans decades across multiple aviation disciplines.
      </p>

      <div class="mt-12 space-y-6">
        {experienceData.map((item) => (
          <div>
            <div class="mb-2 flex items-end justify-between">
              <span class="text-sm font-medium text-navy-700">{item.label}</span>
              <span class="text-lg font-bold text-navy-900">{item.years} years</span>
            </div>
            <div class="h-4 overflow-hidden rounded-full bg-navy-100">
              <div
                class:list={['h-full rounded-full transition-all', item.color]}
                style={`width: ${(item.years / maxYears) * 100}%`}
              ></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Adaptation -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-navy-900 p-8 sm:p-10">
        <h3 class="text-xl font-bold text-white">Built to Adapt</h3>
        <p class="mt-4 leading-relaxed text-navy-300">
          From paper and typewriters through floppy discs and desktop computers to today's laptops, virtual meetings, and cloud technology — PAI has continuously evolved to meet the needs of our clients. When COVID-19 required a shift to fully virtual operations, we pivoted without disrupting a single client service.
        </p>
        <p class="mt-4 leading-relaxed text-navy-300">
          Today, we're developing <strong class="text-white">PAI Academy</strong> — a digital training platform for safety management systems in aviation — continuing our tradition of innovation in service of the aviation community.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
