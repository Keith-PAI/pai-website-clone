---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us" description="PAI Consulting is an SBA-certified Women-Owned Small Business serving the aviation industry since 1978. Pilots, editors, lawyers, and aviation professionals.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
          Let Our Experience Work&nbsp;for&nbsp;You
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300">
          PAI Consulting is an SBA-certified Women-Owned Small Business employing pilots, aviation professionals, editors, technical writers, lawyers, project management professionals, conference planners, and education professionals.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-2xl font-bold sm:text-3xl">Who We Are</h2>
          <p class="mt-4 leading-relaxed text-navy-600">
            Established in 1978, PAI Consulting has been integral to the aerospace industry for over four decades. We work with the Department of Transportation, Federal Aviation Administration, and various aerospace manufacturers to deliver expert consulting services.
          </p>
          <p class="mt-4 leading-relaxed text-navy-600">
            Our organization maintains the experience, abilities, and resources of a large company while providing the personal attention and flexibility of a small business. We employ pilots, analysts, lawyers, and editors with broad aerospace experience.
          </p>
          <p class="mt-4 leading-relaxed text-navy-600">
            From regulatory development and analysis for foreign aviation authorities to systems analyses, evaluations, and audits for air carriers — our team brings deep expertise across the full spectrum of aviation consulting.
          </p>
        </div>
        <div class="space-y-6">
          <!-- Key facts -->
          <div class="rounded-xl border border-navy-100 bg-white p-6">
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-sky-400/10">
                <svg class="h-6 w-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-2xl font-bold text-navy-900">Since 1978</p>
                <p class="text-sm text-navy-500">Over four decades in the aviation industry</p>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-navy-100 bg-white p-6">
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-sky-400/10">
                <svg class="h-6 w-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                </svg>
              </div>
              <div>
                <p class="text-2xl font-bold text-navy-900">27+ Professionals</p>
                <p class="text-sm text-navy-500">Pilots, editors, analysts, lawyers, and more</p>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-navy-100 bg-white p-6">
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-sky-400/10">
                <svg class="h-6 w-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              </div>
              <div>
                <p class="text-2xl font-bold text-navy-900">WOSB Certified</p>
                <p class="text-sm text-navy-500">SBA-certified Women-Owned Small Business</p>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-navy-100 bg-white p-6">
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-sky-400/10">
                <svg class="h-6 w-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                </svg>
              </div>
              <div>
                <p class="text-2xl font-bold text-navy-900">NBAA Member</p>
                <p class="text-sm text-navy-500">National Business Aviation Association</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="border-t border-navy-100 bg-navy-50/50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Our Expertise</h2>
      <p class="mt-3 max-w-2xl text-navy-500">
        We support a wide range of programs and bring deep domain knowledge across aviation, regulatory affairs, and safety.
      </p>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: 'Regulatory Affairs', desc: 'Regulatory development and analysis for U.S. and foreign aviation authorities, including rulemaking support and compliance guidance.' },
          { title: 'Safety Analysis', desc: 'Systems analyses, evaluations, and audits for air carriers and aerospace organizations. Support for ASIAS, CAST, and JIMDAT programs.' },
          { title: 'Technical Writing & Editing', desc: 'Expert editorial services across the full document lifecycle — from drafting through final production.' },
          { title: 'Meeting & Conference Support', desc: 'Complete planning and support for meetings, public hearings, and industry events like Aviation Safety InfoShare.' },
          { title: 'SMS Consulting', desc: 'Safety Management System implementation guidance, gap analysis, and organizational safety culture development.' },
          { title: 'Training & Education', desc: 'Custom training programs, including our upcoming PAI Academy digital training platform for SMS.' },
        ].map((item) => (
          <div class="rounded-xl border border-navy-100 bg-white p-6">
            <h3 class="font-bold text-navy-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-navy-500">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-3">
        <a href="/about/team/" class="group flex items-center gap-4 rounded-xl border border-navy-100 p-6 transition-all hover:border-sky-200 hover:shadow-sm">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-navy-100 text-navy-600 transition-colors group-hover:bg-sky-400/10 group-hover:text-sky-500">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold group-hover:text-sky-600">Our Team</h3>
            <p class="text-sm text-navy-500">Meet our officers, directors, and analysts</p>
          </div>
        </a>
        <a href="/about/history/" class="group flex items-center gap-4 rounded-xl border border-navy-100 p-6 transition-all hover:border-sky-200 hover:shadow-sm">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-navy-100 text-navy-600 transition-colors group-hover:bg-sky-400/10 group-hover:text-sky-500">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold group-hover:text-sky-600">Our History</h3>
            <p class="text-sm text-navy-500">Four decades of aviation consulting</p>
          </div>
        </a>
        <a href="/about/downloads/" class="group flex items-center gap-4 rounded-xl border border-navy-100 p-6 transition-all hover:border-sky-200 hover:shadow-sm">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-navy-100 text-navy-600 transition-colors group-hover:bg-sky-400/10 group-hover:text-sky-500">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold group-hover:text-sky-600">Downloads</h3>
            <p class="text-sm text-navy-500">FRAT tool and SMS resources</p>
          </div>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
