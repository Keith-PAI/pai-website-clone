  <!-- Employees -->
  <section class="py-16" data-section="employees">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold">Employees</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {employees.map((person) => (
          <div class="team-card group rounded-2xl border border-navy-100 bg-white p-6 transition-all hover:border-sky-200 hover:shadow-md" data-role="employees">
            <div class="flex items-center gap-4">
              <div class:list={['flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-sm font-bold', getRoleColor(person.title)]}>
                {getInitials(person.name)}
              </div>
              <div class="min-w-0">
