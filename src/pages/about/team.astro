                        <svg class="h-3 w-3 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                        {fn}
                      </li>
                    ))}
