function getInitials(name: string): string {
  return name.split(' ').filter(n => !n.endsWith('.')).map(n => n[0]).join('').slice(0, 2);
}

function getRoleColor(role: string): string {
  if (role.includes('Chief') || role.includes('CEO') || role.includes('COO') || role.includes('CAO')) return 'bg-sky-400 text-white';
  if (role.includes('Director') || role.includes('Deputy')) return 'bg-navy-700 text-white';
  return 'bg-navy-200 text-navy-700';
}
---

<BaseLayout title="Our Team" description="Meet the PAI Consulting team — 27+ pilots, editors, analysts, lawyers, and aviation professionals serving the industry since 1978.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 flex items-center gap-2 text-sm text-navy-400">
          <a href={url('/')} class="hover:text-sky-400">Home</a>
          <span>/</span>
          <a href={url('/about/')} class="hover:text-sky-400">About</a>
          <span>/</span>
          <span class="text-sky-400">Team</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">Our Team</h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300">
          Pilots, aviation professionals, editors, technical writers, lawyers, project managers, conference planners, and education professionals — all dedicated to aviation excellence.
        </p>
      </div>
    </div>
  </section>

  <!-- Filter Tabs -->
  <section class="sticky top-[73px] z-40 border-b border-navy-100 bg-white/95 backdrop-blur-sm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-1 overflow-x-auto py-3" id="team-tabs" aria-label="Team filters">
        <button data-filter="all" class="team-tab active shrink-0 rounded-lg px-4 py-2 text-sm font-medium text-navy-700 transition-colors hover:bg-navy-50" aria-pressed="true">
          All (27)
