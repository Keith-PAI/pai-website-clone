        <button data-filter="employees" class="team-tab shrink-0 rounded-lg px-4 py-2 text-sm font-medium text-navy-500 transition-colors hover:bg-navy-50" aria-pressed="false">
          Employees (18)
        </button>
      </nav>
    </div>
  </section>

  <!-- Officers -->
  <section class="py-16" data-section="officers">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold">Officers</h2>
      <div class="mt-8 grid gap-6 lg:grid-cols-3">
        {officers.map((person) => (
          <div class="team-card group rounded-2xl border border-navy-100 bg-white p-6 transition-all hover:border-sky-200 hover:shadow-md" data-role="officers">
            <div class="flex items-center gap-4">
              <div class:list={['flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-lg font-bold', getRoleColor(person.title)]}>
                {getInitials(person.name)}
              </div>
              <div class="min-w-0">
                <h3 class="truncate font-bold text-navy-900">{person.name}</h3>
                <p class="truncate text-sm text-navy-500">{person.title}</p>
                <div class="mt-1 flex items-center gap-2">
                  <span class="text-xs text-navy-400">Since {person.started}</span>
                  {person.veteran && (
                    <span class="rounded bg-green-50 px-1.5 py-0.5 text-xs font-medium text-green-700">Veteran</span>
                  )}
                </div>
              </div>
            </div>

            <details class="mt-4">
              <summary class="cursor-pointer text-sm font-medium text-sky-500 hover:text-sky-600">View details</summary>
              <div class="mt-3 space-y-3 border-t border-navy-50 pt-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-navy-400">Education</p>
                  <p class="mt-1 text-sm text-navy-600">{person.education}</p>
                </div>
                {person.certifications && person.certifications.length > 0 && (
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-navy-400">Certifications</p>
                    <div class="mt-1 flex flex-wrap gap-1">
                      {person.certifications.map((cert) => (
                        <span class="rounded-full bg-navy-50 px-2 py-0.5 text-xs text-navy-600">{cert}</span>
                      ))}
                    </div>
                  </div>
                )}
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-navy-400">Key Functions</p>
                  <ul class="mt-1 space-y-1">
                    {person.functions.map((fn) => (
