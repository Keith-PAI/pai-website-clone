---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [
  { value: 'all', label: 'All Posts', count: sortedPosts.length },
  { value: 'sms', label: 'SMS Quick Takes', count: sortedPosts.filter(p => p.data.category === 'sms').length },
  { value: 'editing', label: 'Stet Happens', count: sortedPosts.filter(p => p.data.category === 'editing').length },
  { value: 'meetings', label: 'Meeting Your Needs', count: sortedPosts.filter(p => p.data.category === 'meetings').length },
];

const categoryColors: Record<string, string> = {
  sms: 'bg-emerald-50 text-emerald-700',
  editing: 'bg-violet-50 text-violet-700',
  meetings: 'bg-amber-50 text-amber-700',
};

const categoryLabels: Record<string, string> = {
  sms: 'SMS Quick Takes',
  editing: 'Stet Happens',
  meetings: 'Meeting Your Needs',
};
---

<BaseLayout title="Blog" description="Insights and expertise from PAI Consulting on safety management systems, editing, and meeting support in aviation.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">Blog</h1>
      <p class="mt-4 max-w-2xl text-lg text-navy-300">
        Insights, tips, and expertise from our team on safety management systems, editing best practices, and meeting support.
      </p>
    </div>
  </section>

  <!-- Category Tabs -->
  <section class="sticky top-[73px] z-40 border-b border-navy-100 bg-white/95 backdrop-blur-sm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-1 overflow-x-auto py-3" id="blog-tabs" aria-label="Blog category filters">
        {categories.map((cat) => (
          <button
            data-category={cat.value}
            class:list={[
              'blog-tab shrink-0 rounded-lg px-4 py-2 text-sm font-medium transition-colors hover:bg-navy-50',
              cat.value === 'all' ? 'active bg-sky-400 text-white' : 'text-navy-500',
            ]}
            aria-pressed={cat.value === 'all' ? 'true' : 'false'}
          >
            {cat.label} ({cat.count})
          </button>
        ))}
      </nav>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3" id="posts-grid">
        {sortedPosts.map((post) => (
          <article
            class="blog-post group flex flex-col rounded-2xl border border-navy-100 bg-white transition-all hover:border-sky-200 hover:shadow-md"
            data-category={post.data.category}
          >
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center gap-3">
                <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-medium', categoryColors[post.data.category]]}>
                  {categoryLabels[post.data.category]}
                </span>
                <time class="text-xs text-navy-400" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h2 class="mt-3 text-lg font-bold leading-snug group-hover:text-sky-600">
                <a href={`/blog/${post.id}/`} class="after:absolute after:inset-0 relative">
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-2 line-clamp-3 flex-1 text-sm leading-relaxed text-navy-500">
                {post.data.description}
              </p>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-xs text-navy-400">By {post.data.author}</span>
                <span class="text-sm font-semibold text-sky-500 group-hover:text-sky-600">
                  Read more &rarr;
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div class="py-20 text-center">
          <p class="text-lg text-navy-400">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  .blog-tab.active {
    background-color: var(--color-sky-400);
    color: white;
  }
</style>

<script>
  const tabs = document.querySelectorAll('.blog-tab');
  const posts = document.querySelectorAll('.blog-post');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const category = (tab as HTMLElement).dataset.category;

      tabs.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-pressed', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-pressed', 'true');

      posts.forEach((post) => {
        const el = post as HTMLElement;
        if (category === 'all' || el.dataset.category === category) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
