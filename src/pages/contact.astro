---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Contact PAI Consulting for a quote on editing, meeting support, or SMS consulting services. Located in Fairfax, Virginia.">

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <h1 class="text-3xl font-extrabold sm:text-4xl">Get in Touch</h1>
          <p class="mt-4 text-lg text-navy-500">
            Have a project in mind? We'd love to hear from you. Reach out and our team will get back to you promptly.
          </p>

          <div class="mt-10 space-y-6">
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-sky-400/10">
                <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold">Office</h3>
                <p class="mt-1 text-sm text-navy-500">
                  11325 Random Hills Road<br>
                  Suite 360<br>
                  Fairfax, VA 22030
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-sky-400/10">
                <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold">Phone</h3>
                <p class="mt-1 text-sm text-navy-500">
                  <a href="tel:+17039313131" class="hover:text-sky-500">+1 (703) 931-3131</a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-sky-400/10">
                <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold">Website</h3>
                <p class="mt-1 text-sm text-navy-500">www.PAIconsulting.com</p>
              </div>
            </div>
          </div>

          <!-- Trust badges -->
          <div class="mt-10 flex flex-wrap gap-3">
            <span class="rounded-full bg-navy-50 px-3 py-1.5 text-xs font-medium text-navy-600">
              SBA-Certified WOSB
            </span>
            <span class="rounded-full bg-navy-50 px-3 py-1.5 text-xs font-medium text-navy-600">
              NBAA Member
            </span>
            <span class="rounded-full bg-navy-50 px-3 py-1.5 text-xs font-medium text-navy-600">
              Est. 1978
            </span>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="rounded-2xl border border-navy-100 bg-white p-6 shadow-sm sm:p-8">
            <h2 class="text-xl font-bold">Send Us a Message</h2>
            <p class="mt-2 text-sm text-navy-500">Fill out the form below and we'll get back to you as soon as possible.</p>

            <form action="https://formspree.io/f/placeholder" method="POST" class="mt-6 space-y-5">
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="name" class="block text-sm font-medium text-navy-700">Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="mt-1.5 block w-full rounded-lg border border-navy-200 px-4 py-2.5 text-sm text-navy-900 placeholder-navy-400 transition-colors focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 focus:outline-none"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-navy-700">Email <span class="text-red-500">*</span></label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="mt-1.5 block w-full rounded-lg border border-navy-200 px-4 py-2.5 text-sm text-navy-900 placeholder-navy-400 transition-colors focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 focus:outline-none"
                    placeholder="you@company.com"
                  />
                </div>
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-navy-700">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="mt-1.5 block w-full rounded-lg border border-navy-200 px-4 py-2.5 text-sm text-navy-900 placeholder-navy-400 transition-colors focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 focus:outline-none"
                  placeholder="(555) 123-4567"
                />
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-navy-700">Subject <span class="text-red-500">*</span></label>
                <select
                  id="subject"
                  name="subject"
                  required
                  class="mt-1.5 block w-full rounded-lg border border-navy-200 px-4 py-2.5 text-sm text-navy-900 transition-colors focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 focus:outline-none"
                >
                  <option value="">Select a topic...</option>
                  <option value="editing">Editing & Production</option>
                  <option value="meetings">Meeting Support</option>
                  <option value="sms">SMS Consulting</option>
                  <option value="government">Government Services</option>
                  <option value="general">General Inquiry</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-navy-700">Message <span class="text-red-500">*</span></label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="mt-1.5 block w-full rounded-lg border border-navy-200 px-4 py-2.5 text-sm text-navy-900 placeholder-navy-400 transition-colors focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 focus:outline-none"
                  placeholder="Tell us about your project or question..."
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full rounded-lg bg-sky-400 px-6 py-3 text-base font-semibold text-white shadow-sm transition-all hover:bg-sky-500 hover:shadow-md sm:w-auto"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
