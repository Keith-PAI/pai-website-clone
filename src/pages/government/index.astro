---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/paths';
---

<BaseLayout title="Government Client Services" description="PAI Consulting provides specialized services for federal, state, and local government agencies. Purchase with your Government P-Card.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 flex items-center gap-2 text-sm text-navy-400">
          <a href={url('/')} class="hover:text-sky-400">Home</a>
          <span>/</span>
          <span class="text-sky-400">Government Services</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
          Government Client Services
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300">
          PAI provides comprehensive services tailored to meet the unique needs of government agencies and organizations. With decades of experience supporting federal, state, and local government entities, we offer specialized expertise across multiple disciplines.
        </p>
      </div>
    </div>
  </section>

  <!-- P-Card Banner -->
  <section class="bg-sky-400 py-4">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <p class="text-base font-semibold text-white">
        These services can be purchased using your Government Purchase Card (P-Card)
      </p>
    </div>
  </section>

  <!-- Available Services -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Available Services</h2>
      <p class="mt-3 max-w-2xl text-navy-500">
        Our team of subject matter experts ensures all deliverables meet the highest standards of accuracy, clarity, and compliance with applicable laws and regulations.
      </p>

      <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <!-- Editing -->
        <a href={url('/services/editing-production/')} class="group rounded-2xl border border-navy-100 bg-white p-8 transition-all hover:border-sky-200 hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-bold group-hover:text-sky-600">Editing &amp; Production</h3>
          <p class="mt-3 text-sm text-navy-500">
            Regulatory drafting, rulemaking support, report and white paper development, copyediting, proofreading, and formatting — all compliant with GPO Style Manual and plain language standards.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-semibold text-sky-500">
            View details <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>

        <!-- Meeting Support -->
        <a href={url('/services/meeting-support/')} class="group rounded-2xl border border-navy-100 bg-white p-8 transition-all hover:border-sky-200 hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-bold group-hover:text-sky-600">Meeting Support</h3>
          <p class="mt-3 text-sm text-navy-500">
            Complete planning services and meeting support for public hearings, conferences, and government meetings — documentation, facilitation, and coordination.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-semibold text-sky-500">
            View details <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>

        <!-- SMS -->
        <a href={url('/services/sms-consulting/')} class="group rounded-2xl border border-navy-100 bg-white p-8 transition-all hover:border-sky-200 hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-bold group-hover:text-sky-600">SMS Consulting</h3>
          <p class="mt-3 text-sm text-navy-500">
            Safety Management System consulting supporting 14 CFR Part 5 compliance, gap analysis, and organizational SMS implementation for government aviation programs.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-semibold text-sky-500">
            View details <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>

        <!-- Coming Soon cards -->
        <div class="rounded-2xl border border-dashed border-navy-200 bg-navy-50/50 p-8">
          <span class="inline-flex items-center rounded-full bg-navy-100 px-3 py-1 text-xs font-semibold text-navy-600">Coming Soon</span>
          <h3 class="mt-4 text-xl font-bold text-navy-400">Aerospace Safety Services</h3>
          <p class="mt-3 text-sm text-navy-400">Expanded safety analysis and assessment services for government aviation programs.</p>
        </div>

        <div class="rounded-2xl border border-dashed border-navy-200 bg-navy-50/50 p-8">
          <span class="inline-flex items-center rounded-full bg-navy-100 px-3 py-1 text-xs font-semibold text-navy-600">Coming Soon</span>
          <h3 class="mt-4 text-xl font-bold text-navy-400">Conference Planning</h3>
          <p class="mt-3 text-sm text-navy-400">Full-service conference planning and event management for government agencies.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Procurement Info -->
  <section class="border-t border-navy-100 bg-navy-50/50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Procurement Information</h2>
      <p class="mt-3 max-w-2xl text-navy-500">
        Making it easy to work with us through standard government procurement channels.
      </p>

      <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-navy-100 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-400/10">
            <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">Government P-Card</h3>
          <p class="mt-2 text-sm text-navy-500">
            All services can be purchased directly using your Government Purchase Card — streamlining procurement with no contract vehicle required for micro-purchases.
          </p>
        </div>

        <div class="rounded-xl border border-navy-100 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-400/10">
            <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 00-1.883 2.542l.857 6a2.25 2.25 0 002.227 1.932H19.05a2.25 2.25 0 002.227-1.932l.857-6a2.25 2.25 0 00-1.883-2.542m-16.5 0V6A2.25 2.25 0 016 3.75h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 001.06.44H18A2.25 2.25 0 0120.25 9v.776" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">NAICS Codes</h3>
          <p class="mt-2 text-sm text-navy-500">
            We maintain applicable NAICS codes for our service areas. Contact us for specific codes relevant to your procurement needs.
          </p>
        </div>

        <div class="rounded-xl border border-navy-100 bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-400/10">
            <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">WOSB Certified</h3>
          <p class="mt-2 text-sm text-navy-500">
            SBA-certified Women-Owned Small Business, supporting set-aside and sole-source procurement requirements.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Clients & Programs -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Programs We Support</h2>
      <p class="mt-3 max-w-2xl text-navy-500">
        PAI Consulting has deep experience supporting critical government aviation programs.
      </p>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'ASIAS', desc: 'Aviation Safety Information Analysis and Sharing' },
          { name: 'CAST', desc: 'Commercial Aviation Safety Team' },
          { name: 'JIMDAT', desc: 'Joint Implementation Measurement Data Analysis Team' },
          { name: 'InfoShare', desc: 'Aviation Safety Information Analysis and Sharing Conference' },
          { name: 'FAA', desc: 'Federal Aviation Administration regulatory support' },
          { name: 'DOT', desc: 'Department of Transportation program support' },
          { name: 'Rulemaking', desc: 'Regulatory drafting and rulemaking support' },
          { name: 'Public Hearings', desc: 'Meeting support for government public hearings' },
        ].map((program) => (
          <div class="rounded-xl border border-navy-100 bg-white p-5">
            <h3 class="text-lg font-bold text-navy-900">{program.name}</h3>
            <p class="mt-1 text-xs text-navy-500">{program.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-900 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Ready to Work Together?</h2>
      <p class="mt-4 text-navy-300">
        Contact us to discuss your agency's needs. We'll help identify the right services and procurement approach for your project.
      </p>
      <a
        href={url('/contact/')}
        class="mt-8 inline-flex items-center rounded-lg bg-sky-400 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-sky-500"
      >
        Contact Us
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
