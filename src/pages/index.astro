---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../utils/paths';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const categoryColors: Record<string, string> = {
  sms: 'bg-emerald-50 text-emerald-700',
  editing: 'bg-violet-50 text-violet-700',
  meetings: 'bg-amber-50 text-amber-700',
};
const categoryLabels: Record<string, string> = {
  sms: 'SMS Quick Takes',
  editing: 'Stet Happens',
  meetings: 'Meeting Your Needs',
};
---

<BaseLayout title="Aviation Consulting Services" description="PAI Consulting provides expert editing, meeting support, and SMS consulting services for government and private sector aviation clients since 1978.">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy-950 py-20 sm:py-28 lg:py-36">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--color-sky-400)_0%,_transparent_50%)] opacity-10"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-sky-400">Since 1978</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Helping You Succeed in&nbsp;Aviation
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300 sm:text-xl">
          A broad range of consulting services in aviation, regulatory affairs, and training — serving government agencies and private sector organizations worldwide.
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href={url('/contact/')}
            class="inline-flex items-center justify-center rounded-lg bg-sky-400 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-sky-400/25 transition-all hover:bg-sky-500 hover:shadow-sky-500/25"
          >
            Get a Quote
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={url('/services/editing-production/')}
            class="inline-flex items-center justify-center rounded-lg border border-navy-600 px-6 py-3 text-base font-semibold text-navy-200 transition-all hover:border-navy-400 hover:text-white"
          >
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold sm:text-4xl">Our Services</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-navy-500">
          Comprehensive consulting solutions tailored for aviation professionals and organizations.
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-3">
        <!-- Editing & Production -->
        <div class="group relative rounded-2xl border border-navy-100 bg-white p-8 shadow-sm transition-all hover:border-sky-200 hover:shadow-md hover:shadow-sky-400/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-bold">Editing &amp; Production</h3>
          <p class="mt-3 text-navy-500 leading-relaxed">
            From copyediting to technical document drafting — our editors transform your content from good to great with precision and clarity.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-navy-600">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Copyediting &amp; Proofreading
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Technical Document Drafting
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Localization &amp; Fact-Checking
            </li>
          </ul>
          <a href={url('/services/editing-production/')} class="mt-6 inline-flex items-center text-sm font-semibold text-sky-500 transition-colors hover:text-sky-600">
            Learn more
            <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Meeting Support -->
        <div class="group relative rounded-2xl border border-navy-100 bg-white p-8 shadow-sm transition-all hover:border-sky-200 hover:shadow-md hover:shadow-sky-400/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-bold">Meeting Support</h3>
          <p class="mt-3 text-navy-500 leading-relaxed">
            Professional documentation, facilitation, and complete planning support to make your meetings effective and well-documented.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-navy-600">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Documentation &amp; Minutes
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Facilitation &amp; Tech Support
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Pre &amp; Post-Meeting Coordination
            </li>
          </ul>
          <a href={url('/services/meeting-support/')} class="mt-6 inline-flex items-center text-sm font-semibold text-sky-500 transition-colors hover:text-sky-600">
            Learn more
            <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- SMS Consulting -->
        <div class="group relative rounded-2xl border border-navy-100 bg-white p-8 shadow-sm transition-all hover:border-sky-200 hover:shadow-md hover:shadow-sky-400/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-bold">SMS Consulting</h3>
          <p class="mt-3 text-navy-500 leading-relaxed">
            Safety Management System consulting and training — helping organizations build a formal, top-down approach to managing safety risk.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-navy-600">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Safety Risk Management
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Safety Assurance &amp; Policy
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              On-Demand Training (Coming Soon)
            </li>
          </ul>
          <a href={url('/services/sms-consulting/')} class="mt-6 inline-flex items-center text-sm font-semibold text-sky-500 transition-colors hover:text-sky-600">
            Learn more
            <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / Trust Bar -->
  <section class="border-y border-navy-100 bg-navy-50/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        <div class="text-center">
          <p class="text-3xl font-extrabold text-navy-900 sm:text-4xl">45+</p>
          <p class="mt-2 text-sm font-medium text-navy-500">Years of Experience</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-extrabold text-navy-900 sm:text-4xl">248</p>
          <p class="mt-2 text-sm font-medium text-navy-500">Combined Years in Aviation Analysis</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-extrabold text-navy-900 sm:text-4xl">27+</p>
          <p class="mt-2 text-sm font-medium text-navy-500">Expert Team Members</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-extrabold text-navy-900 sm:text-4xl">WOSB</p>
          <p class="mt-2 text-sm font-medium text-navy-500">SBA-Certified Women-Owned</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Government & Private Sector Split -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-2">
        <!-- Government -->
        <div class="relative overflow-hidden rounded-2xl bg-navy-900 p-8 sm:p-10">
          <div class="absolute right-0 top-0 h-32 w-32 translate-x-8 -translate-y-8 rounded-full bg-sky-400/10"></div>
          <div class="relative">
            <span class="inline-flex items-center rounded-full bg-sky-400/10 px-3 py-1 text-xs font-semibold text-sky-400">
              Government
            </span>
            <h3 class="mt-4 text-2xl font-bold text-white">Government Client Services</h3>
            <p class="mt-3 text-navy-300 leading-relaxed">
              Decades of experience supporting federal, state, and local government entities with specialized expertise in regulatory drafting, rulemaking support, and compliance.
            </p>
            <p class="mt-4 text-sm font-medium text-sky-400">
              Services available via Government Purchase Card (P-Card)
            </p>
            <a
              href={url('/government/')}
              class="mt-6 inline-flex items-center rounded-lg border border-navy-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:border-sky-400 hover:text-sky-400"
            >
              Government Services Info
              <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

        <!-- Private Sector -->
        <div class="relative overflow-hidden rounded-2xl border-2 border-navy-100 bg-white p-8 sm:p-10">
          <div class="absolute right-0 top-0 h-32 w-32 translate-x-8 -translate-y-8 rounded-full bg-navy-100"></div>
          <div class="relative">
            <span class="inline-flex items-center rounded-full bg-navy-100 px-3 py-1 text-xs font-semibold text-navy-700">
              Private Sector
            </span>
            <h3 class="mt-4 text-2xl font-bold">Private Sector Services</h3>
            <p class="mt-3 text-navy-500 leading-relaxed">
              Expert services for aviation companies, manufacturers, and aerospace organizations — from document editing to complete safety management system implementation.
            </p>
            <p class="mt-4 text-sm font-medium text-navy-700">
              Transparent pricing available in our service catalog
            </p>
            <a
              href={url('/services/editing-production/')}
              class="mt-6 inline-flex items-center rounded-lg bg-navy-900 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-navy-800"
            >
              View Services
              <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FRAT Tool CTA -->
  <section class="bg-sky-400 py-16">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Free Flight Risk Assessment Tool</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/90">
        Try our free online FRAT — a practical tool for evaluating flight risk before every operation.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="https://jw2750.github.io/PAI-FRAT/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-sky-600 shadow-lg transition-all hover:bg-navy-50"
        >
          Try the FRAT Tool
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
          </svg>
        </a>
        <a
          href={url('/contact/')}
          class="inline-flex items-center rounded-lg border-2 border-white px-6 py-3 text-base font-semibold text-white transition-all hover:bg-white/10"
        >
          Contact Us About SMS Tools
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Blog Posts -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-3xl font-bold sm:text-4xl">Latest from Our Blog</h2>
          <p class="mt-3 text-navy-500">Insights and expertise from our team.</p>
        </div>
        <a href={url('/blog/')} class="hidden text-sm font-semibold text-sky-500 hover:text-sky-600 sm:inline-flex sm:items-center">
          View all posts
          <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <div class="mt-10 grid gap-8 md:grid-cols-3">
        {recentPosts.map((post) => (
          <a href={url(`/blog/${post.id}/`)} class="group flex flex-col rounded-2xl border border-navy-100 bg-white p-6 transition-all hover:border-sky-200 hover:shadow-md">
            <div class="flex items-center gap-3">
              <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-medium', categoryColors[post.data.category]]}>
                {categoryLabels[post.data.category]}
              </span>
              <time class="text-xs text-navy-400" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h3 class="mt-3 flex-1 text-lg font-bold leading-snug group-hover:text-sky-600">{post.data.title}</h3>
            <p class="mt-2 line-clamp-2 text-sm text-navy-500">{post.data.description}</p>
            <span class="mt-4 text-sm font-semibold text-sky-500 group-hover:text-sky-600">Read more &rarr;</span>
          </a>
        ))}
      </div>
      <a href={url('/blog/')} class="mt-8 inline-flex items-center text-sm font-semibold text-sky-500 hover:text-sky-600 sm:hidden">
        View all posts
        <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold sm:text-4xl">Ready to Get Started?</h2>
      <p class="mt-4 text-lg text-navy-500">
        Whether you need expert editing, meeting support, or safety management consulting — our team of aviation professionals is here to help.
      </p>
      <a
        href={url('/contact/')}
        class="mt-8 inline-flex items-center rounded-lg bg-navy-900 px-8 py-3.5 text-base font-semibold text-white shadow-lg transition-all hover:bg-navy-800"
      >
        Schedule a Consultation
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>
