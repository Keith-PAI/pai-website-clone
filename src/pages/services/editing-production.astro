---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Copyediting',
    description: 'Polishing your content while preserving your voice. From light touch-ups to heavy restructuring, we ensure your writing is crisp, clean, and concise.',
    icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z',
  },
  {
    title: 'Proofreading',
    description: 'The final line of defense before publication. We catch errors that slip through earlier editing stages to ensure a polished final product.',
    icon: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Technical Document Drafting',
    description: 'Creating clear, accurate, and comprehensive documentation from your source material. Our writers specialize in aviation and regulatory content.',
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  },
  {
    title: 'Localization Editing',
    description: 'Adapting translated content for cultural relevance and readability. We ensure your message resonates with the target audience without re-translating.',
    icon: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
  },
  {
    title: 'Fact-Checking',
    description: 'Ensuring the accuracy of your content in an era where credibility matters more than ever. We verify claims, data, and references systematically.',
    icon: 'M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15',
  },
  {
    title: 'Formatting',
    description: 'Arranging text and graphics to meet publication standards. We ensure your documents look professional and enhance readability across all formats.',
    icon: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
  },
];
---

<BaseLayout title="Editing & Production Services" description="Professional document editing, copyediting, proofreading, technical writing, and production services for aviation and government clients.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 flex items-center gap-2 text-sm text-navy-400">
          <a href="/" class="hover:text-sky-400">Home</a>
          <span>/</span>
          <span class="text-navy-300">Services</span>
          <span>/</span>
          <span class="text-sky-400">Editing &amp; Production</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
          Document Editing &amp; Production
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300">
          Our editors are the secret sauce that takes your words from good to great — reshaping your content to fit your audience so your messaging resonates clearly. All edits use Microsoft Word's Track Changes.
        </p>
        <div class="mt-8">
          <a
            href="/contact/"
            class="inline-flex items-center rounded-lg bg-sky-400 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-sky-500"
          >
            Request a Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">What We Offer</h2>
      <p class="mt-3 max-w-2xl text-navy-500">
        Our team of editors, technical writers, and production specialists brings expertise in various editorial styles, including the U.S. Government Publishing Office Style Manual, plain language, and house style guides.
      </p>

      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <div class="rounded-xl border border-navy-100 bg-white p-6 transition-all hover:border-sky-200 hover:shadow-sm">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-400/10">
              <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path d={service.icon} />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold">{service.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-navy-500">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="border-t border-navy-100 bg-navy-50/50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Our Process</h2>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { step: '01', title: 'Submit', desc: 'Send us your Microsoft Word document with any style guides or special instructions.' },
          { step: '02', title: 'Review', desc: 'Our editors assess the document scope and assign the right specialist for your content.' },
          { step: '03', title: 'Edit', desc: 'All edits are made using Track Changes so you can review and accept each modification.' },
          { step: '04', title: 'Deliver', desc: 'Receive your polished document with all changes tracked and a summary of key edits.' },
        ].map((item) => (
          <div class="relative">
            <span class="text-4xl font-extrabold text-navy-200">{item.step}</span>
            <h3 class="mt-2 text-lg font-bold">{item.title}</h3>
            <p class="mt-2 text-sm text-navy-500">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Government Note -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-navy-900 p-8 sm:p-10">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h3 class="text-xl font-bold text-white">Government Client?</h3>
            <p class="mt-2 text-navy-300">
              These services can be purchased using your Government Purchase Card (P-Card). We support NAICS codes and various contract vehicles.
            </p>
          </div>
          <a
            href="/government/"
            class="inline-flex shrink-0 items-center rounded-lg border border-navy-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:border-sky-400 hover:text-sky-400"
          >
            Government Info
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
