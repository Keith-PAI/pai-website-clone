---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/paths';
---

<BaseLayout title="Our Services" description="PAI Consulting offers editing & production, meeting support, and SMS consulting services for government and private sector aviation clients.">

  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">Our Services</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-navy-300">
        Comprehensive consulting solutions tailored for aviation professionals and organizations — both government and private sector.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-3">

        <a href={url('/services/editing-production/')} class="group rounded-2xl border border-navy-100 bg-white p-8 transition-all hover:border-sky-200 hover:shadow-lg hover:shadow-sky-400/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h2 class="mt-6 text-xl font-bold group-hover:text-sky-600">Editing &amp; Production</h2>
          <p class="mt-3 text-navy-500">Copyediting, proofreading, technical drafting, localization, fact-checking, and formatting services.</p>
          <span class="mt-4 inline-flex items-center text-sm font-semibold text-sky-500">
            Learn more <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>

        <a href={url('/services/meeting-support/')} class="group rounded-2xl border border-navy-100 bg-white p-8 transition-all hover:border-sky-200 hover:shadow-lg hover:shadow-sky-400/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h2 class="mt-6 text-xl font-bold group-hover:text-sky-600">Meeting Support</h2>
          <p class="mt-3 text-navy-500">Documentation, facilitation, and complete pre/post-meeting coordination for up to 50 attendees.</p>
          <span class="mt-4 inline-flex items-center text-sm font-semibold text-sky-500">
            Learn more <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>

        <a href={url('/services/sms-consulting/')} class="group rounded-2xl border border-navy-100 bg-white p-8 transition-all hover:border-sky-200 hover:shadow-lg hover:shadow-sky-400/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-400/10 text-sky-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h2 class="mt-6 text-xl font-bold group-hover:text-sky-600">SMS Consulting</h2>
          <p class="mt-3 text-navy-500">Safety Management System implementation, training, and consulting for aviation organizations.</p>
          <span class="mt-4 inline-flex items-center text-sm font-semibold text-sky-500">
            Learn more <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>

      </div>

      <div class="mt-12 rounded-2xl border border-navy-100 bg-navy-50/50 p-8 text-center">
        <h2 class="text-xl font-bold text-navy-900">Transparent Pricing</h2>
        <p class="mt-2 text-navy-500">View our complete service catalog with pricing for editing, drafting, meeting support, and SMS training.</p>
        <a href={url('/services/pricing/')} class="mt-4 inline-flex items-center rounded-lg bg-sky-400 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-sky-500">
          View Pricing
          <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
