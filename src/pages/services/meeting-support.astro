---
import BaseLayout from '../../layouts/BaseLayout.astro';

const packages = [
  {
    name: 'Documentation',
    description: 'Professional note-taking and attendance tracking for your meetings.',
    price4hr: '$5,287',
    price8hr: '$8,812',
    features: [
      'Detailed discussion notes',
      'Attendance tracking & verification',
      'Post-meeting edited minutes',
      'Action item documentation',
      'Materials distribution',
    ],
  },
  {
    name: 'Facilitation',
    description: 'Technical support and presentation management to keep your meetings running smoothly.',
    price4hr: '$2,475',
    price8hr: '$3,140',
    features: [
      'Slide operation & transitions',
      'Breakout room management',
      'Poll administration',
      'Chat monitoring',
      'Technical troubleshooting',
    ],
  },
  {
    name: 'Documentation & Facilitation',
    description: 'Complete meeting support combining both services for maximum effectiveness.',
    price4hr: '$5,662',
    price8hr: '$9,562',
    featured: true,
    features: [
      'Everything in Documentation',
      'Everything in Facilitation',
      'Comprehensive meeting coverage',
      'Single point of contact',
      'Priority scheduling',
    ],
  },
];
---

<BaseLayout title="Meeting Support Services" description="Professional meeting documentation, facilitation, and planning support services for government and private sector clients.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 flex items-center gap-2 text-sm text-navy-400">
          <a href="/" class="hover:text-sky-400">Home</a>
          <span>/</span>
          <span class="text-navy-300">Services</span>
          <span>/</span>
          <span class="text-sky-400">Meeting Support</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
          Meeting Support
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300">
          Think of meeting support as the backbone of your business gatherings. Our professionals ensure your meetings are effective, productive, and well-documented.
        </p>
        <div class="mt-8">
          <a
            href="/contact/"
            class="inline-flex items-center rounded-lg bg-sky-400 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-sky-500"
          >
            Request a Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Packages -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Support Packages</h2>
      <p class="mt-3 max-w-2xl text-navy-500">
        Choose the level of support that fits your needs. Each package is available in 4-hour or 8-hour formats.
      </p>

      <div class="mt-12 grid gap-8 lg:grid-cols-3">
        {packages.map((pkg) => (
          <div class:list={[
            'relative rounded-2xl p-8 transition-all',
            pkg.featured
              ? 'border-2 border-sky-400 bg-white shadow-lg shadow-sky-400/10'
              : 'border border-navy-100 bg-white hover:border-sky-200 hover:shadow-sm',
          ]}>
            {pkg.featured && (
              <span class="absolute -top-3 left-6 rounded-full bg-sky-400 px-3 py-1 text-xs font-bold text-white">
                Most Popular
              </span>
            )}
            <h3 class="text-xl font-bold">{pkg.name}</h3>
            <p class="mt-2 text-sm text-navy-500">{pkg.description}</p>

            <div class="mt-6 flex items-end gap-4 border-b border-navy-100 pb-6">
              <div>
                <p class="text-xs font-medium uppercase tracking-wider text-navy-400">4 Hours</p>
                <p class="text-2xl font-bold text-navy-900">{pkg.price4hr}</p>
              </div>
              <div>
                <p class="text-xs font-medium uppercase tracking-wider text-navy-400">8 Hours</p>
                <p class="text-2xl font-bold text-navy-900">{pkg.price8hr}</p>
              </div>
            </div>

            <ul class="mt-6 space-y-3">
              {pkg.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm text-navy-600">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <a
              href="/contact/"
              class:list={[
                'mt-8 block rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors',
                pkg.featured
                  ? 'bg-sky-400 text-white hover:bg-sky-500'
                  : 'bg-navy-50 text-navy-700 hover:bg-navy-100',
              ]}
            >
              Get Started
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="border-t border-navy-100 bg-navy-50/50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">What's Included</h2>

      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-400/10">
            <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">Pre-Meeting</h3>
          <ul class="mt-3 space-y-2 text-sm text-navy-500">
            <li>Scheduling polls and venue coordination</li>
            <li>Online meeting platform setup (Zoom or client systems)</li>
            <li>Invitations and RSVP tracking</li>
            <li>Agenda preparation and document distribution</li>
          </ul>
        </div>

        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-400/10">
            <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">During Meeting</h3>
          <ul class="mt-3 space-y-2 text-sm text-navy-500">
            <li>15-minute early arrival and setup</li>
            <li>Slide operation and chat monitoring</li>
            <li>Breakout room assignment and poll administration</li>
            <li>Detailed discussion notes and attendance capture</li>
          </ul>
        </div>

        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-sky-400/10">
            <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold">Post-Meeting</h3>
          <ul class="mt-3 space-y-2 text-sm text-navy-500">
            <li>Professionally edited meeting minutes</li>
            <li>Action item tracking and documentation</li>
            <li>Deliverable and feedback distribution</li>
            <li>Follow-up coordination support</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Limitations Note -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-navy-200 bg-navy-50 p-6">
        <h3 class="font-bold text-navy-900">Important Notes</h3>
        <ul class="mt-3 space-y-2 text-sm text-navy-600">
          <li>Meeting support covers up to <strong>50 attendees</strong> for a maximum of <strong>8 hours</strong>.</li>
          <li>This service does <em>not</em> include making attendee travel arrangements or in-person support.</li>
          <li>All meeting support is provided remotely via virtual meeting platforms.</li>
        </ul>
      </div>
    </div>
  </section>

</BaseLayout>
