---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/paths';

const editingPricing = [
  { service: 'Localization Editing', tiers: ['$425', '$850', '$1,275', '$1,700', '$2,125'] },
  { service: 'Fact-Checking', tiers: ['$550', '$1,100', '$1,650', '$2,200', '$2,750'] },
  { service: 'Copyediting', tiers: ['$375', '$750', '$1,125', '$1,500', '$1,875'] },
  { service: 'Formatting', tiers: ['$250', '$500', '$750', '$1,000', '$1,250'] },
  { service: 'Proofreading', tiers: ['$125', '$250', '$375', '$500', '$625'] },
];

const wordTiers = ['1–2,500', '2,501–5,000', '5,001–7,500', '7,501–10,000', '10,001–12,500'];

const draftingPricing = [
  { pages: '1–50', price: '$1,999' },
  { pages: '51–100', price: '$3,999' },
  { pages: '101–150', price: '$5,999' },
  { pages: '151–200', price: '$7,999' },
  { pages: '201–250', price: '$9,999' },
];

const meetingPricing = [
  { service: 'Documentation', price4: '$5,287', price8: '$8,812' },
  { service: 'Facilitation', price4: '$2,475', price8: '$3,140' },
  { service: 'Documentation & Facilitation', price4: '$5,662', price8: '$9,562' },
];
---

<BaseLayout title="Service Catalog & Pricing" description="Transparent pricing for PAI Consulting's editing, document production, and meeting support services.">

  <!-- Hero -->
  <section class="bg-navy-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 flex items-center gap-2 text-sm text-navy-400">
          <a href={url('/')} class="hover:text-sky-400">Home</a>
          <span>/</span>
          <a href={url('/services/')} class="hover:text-sky-400">Services</a>
          <span>/</span>
          <span class="text-sky-400">Pricing</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
          Service Catalog &amp; Pricing
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-300">
          Transparent pricing for our private sector services. Government clients — these services are also available via P-Card.
        </p>
      </div>
    </div>
  </section>

  <!-- Editing & Production -->
  <section class="py-16" id="editing">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Editing &amp; Production</h2>
      <p class="mt-3 text-navy-500">Pricing based on word count. All edits delivered in Microsoft Word with Track Changes.</p>

      <div class="mt-8 overflow-x-auto">
        <table class="w-full min-w-[640px] text-sm">
          <thead>
            <tr class="border-b-2 border-navy-200">
              <th class="pb-3 pr-4 text-left font-semibold text-navy-700">Service</th>
              {wordTiers.map((tier) => (
                <th class="pb-3 px-3 text-center font-semibold text-navy-700">
                  <span class="block text-xs text-navy-400">words</span>
                  {tier}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {editingPricing.map((row, i) => (
              <tr class:list={['border-b border-navy-100', i % 2 === 0 ? 'bg-navy-50/50' : '']}>
                <td class="py-3 pr-4 font-medium text-navy-900">{row.service}</td>
                {row.tiers.map((price) => (
                  <td class="px-3 py-3 text-center text-navy-700">{price}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Technical Document Drafting -->
  <section class="border-t border-navy-100 bg-navy-50/50 py-16" id="drafting">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Technical Document Drafting</h2>
      <p class="mt-3 text-navy-500">Pricing based on page count. Includes research, drafting, and one round of revisions.</p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {draftingPricing.map((item) => (
          <div class="rounded-xl border border-navy-100 bg-white p-5 text-center">
            <p class="text-sm font-medium text-navy-400">{item.pages} pages</p>
            <p class="mt-2 text-2xl font-bold text-navy-900">{item.price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Meeting Support -->
  <section class="py-16" id="meetings">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Meeting Support</h2>
      <p class="mt-3 text-navy-500">Available in 4-hour and 8-hour formats. Up to 50 attendees, remote only.</p>

      <div class="mt-8 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-navy-200">
              <th class="pb-3 pr-4 text-left font-semibold text-navy-700">Package</th>
              <th class="pb-3 px-6 text-center font-semibold text-navy-700">4 Hours</th>
              <th class="pb-3 px-6 text-center font-semibold text-navy-700">8 Hours</th>
            </tr>
          </thead>
          <tbody>
            {meetingPricing.map((row, i) => (
              <tr class:list={['border-b border-navy-100', i % 2 === 0 ? 'bg-navy-50/50' : '']}>
                <td class="py-4 pr-4 font-medium text-navy-900">{row.service}</td>
                <td class="px-6 py-4 text-center text-lg font-semibold text-navy-900">{row.price4}</td>
                <td class="px-6 py-4 text-center text-lg font-semibold text-navy-900">{row.price8}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-6 rounded-xl border border-navy-200 bg-navy-50 p-5 text-sm text-navy-600">
        <strong>Note:</strong> Meeting support covers up to 50 attendees for a maximum of 8 hours. Does not include in-person support or attendee travel arrangements. No discounts for partial component selection.
      </div>
    </div>
  </section>

  <!-- SMS Training Pricing -->
  <section class="border-t border-navy-100 bg-navy-50/50 py-16" id="training">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3">
        <h2 class="text-2xl font-bold sm:text-3xl">SMS Training</h2>
        <span class="rounded-full bg-sky-400/10 px-3 py-1 text-xs font-semibold text-sky-600">Coming Soon</span>
      </div>
      <p class="mt-3 text-navy-500">11-module course with certificate. Self-paced or hybrid 6-week format.</p>

      <div class="mt-8 grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-navy-100 bg-white p-6 text-center">
          <p class="text-sm font-medium text-navy-400">2–5 accesses</p>
          <p class="mt-2 text-3xl font-bold text-sky-500">15%</p>
          <p class="mt-1 text-sm text-navy-500">volume discount</p>
        </div>
        <div class="rounded-xl border border-navy-100 bg-white p-6 text-center">
          <p class="text-sm font-medium text-navy-400">6–9 accesses</p>
          <p class="mt-2 text-3xl font-bold text-sky-500">20%</p>
          <p class="mt-1 text-sm text-navy-500">volume discount</p>
        </div>
        <div class="rounded-xl border border-navy-100 bg-white p-6 text-center">
          <p class="text-sm font-medium text-navy-400">10+ accesses</p>
          <p class="mt-2 text-3xl font-bold text-sky-500">25%</p>
          <p class="mt-1 text-sm text-navy-500">volume discount</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold sm:text-3xl">Need a Custom Quote?</h2>
      <p class="mt-4 text-navy-500">
        For projects outside these standard tiers, or for government procurement inquiries, contact us for a tailored quote.
      </p>
      <a href={url('/contact/')} class="mt-8 inline-flex items-center rounded-lg bg-sky-400 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-sky-500">
        Request a Quote
      </a>
    </div>
  </section>

</BaseLayout>
